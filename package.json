{
  "name": "@miao/miao-code",
  "version": "1.0.0",
  "description": "一个智能的 AI 编程助手，基于 Claude Code 开发",
  "keywords": ["ai", "programming", "assistant", "miao", "claude"],
  "author": "喵哥团队",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/miaoge2026/MiaoCode.git"
  },
  "bugs": {
    "url": "https://github.com/miaoge2026/MiaoCode/issues"
  },
  "homepage": "https://github.com/miaoge2026/MiaoCode#readme",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./tools": "./dist/tools/index.js",
    "./ui": "./dist/ui/index.js",
    "./services": "./dist/services/index.js"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "precommit": "npm run lint && npm run format && npm run type-check",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.9.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ink": "^4.0.0",
    "react": "^18.2.0",
    "zod": "^3.22.0",
    "lodash-es": "^4.17.21",
    "p-map": "^6.0.0",
    "react-reconciler": "^0.29.0",
    "semver": "^7.5.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@types/react": "^18.2.20",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^8.47.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "husky": "^8.0.0",
    "jest": "^29.6.0",
    "jest-environment-jsdom": "^29.6.0",
    "lint-staged": "^14.0.0",
    "prettier": "^3.0.0",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.6",
    "vite": "^4.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "ai",
    "programming-assistant",
    "claude",
    "miao",
    "code-generation",
    "intelligent-agent",
    "tool-system",
    "performance-optimization",
    "machine-learning",
    "reinforcement-learning"
  ]
}