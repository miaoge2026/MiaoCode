{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@core/*": ["src/core/*"],
      "@utils/*": ["src/utils/*"],
      "@types/*": ["src/types/*"]
    },

    /* Source Maps */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Optimization */
    "removeComments": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,

    /* Advanced */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolvePackageJsonExports": "node16",
    "resolvePackageJsonImports": "node16",
    "moduleSuffixes": [".js", ".ts", ".tsx"]
  },
  "include": ["src", "tests", "types"],
  "exclude": ["node_modules", "dist", "**/*.d.ts"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}